{
  "name": "strata",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend": "node backend/server.mjs",
    "ingest:indicators": "node ingestion/update-indicators.mjs",
    "memo:export": "node --import tsx/esm reporting/export-memo.mjs",
    "snapshot:persist": "node --import tsx/esm reporting/persist-snapshot.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "monitor:regulations:once": "node monitoring/regulation-monitor.mjs --once",
    "monitor:regulations": "node monitoring/regulation-monitor.mjs --schedule \"0 */6 * * *\"",
    "research": "node --import tsx/esm research/run.ts"
  },
  "dependencies": {
    "express": "^5.1.0",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.17.2",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.20.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
